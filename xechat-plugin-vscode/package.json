{
  "name": "xechat-plugin-vscode",
  "displayName": "XEChat",
  "description": "XEChat for VSCode",
  "version": "0.0.1",
  "publisher": "xeblog",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:xechat.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xechat.openChat",
        "title": "XEChat: 打开聊天"
      }
    ],
    "configuration": {
      "title": "XEChat",
      "properties": {
        "xechat.serverUrl": {
          "type": "string",
          "default": "ws://localhost:1025/xechat",
          "description": "XEChat WebSocket 服务地址"
        },
        "xechat.nickname": {
          "type": "string",
          "default": "xechat_user",
          "description": "XEChat 聊天昵称"
        },
        "xechat.autoReconnect": {
          "type": "boolean",
          "default": true,
          "description": "连接断开后自动重连"
        },
        "xechat.reconnectIntervalSeconds": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "自动重连间隔（秒）"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "typecheck": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
