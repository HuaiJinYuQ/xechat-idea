{
  "name": "xechat-plugin-vscode",
  "displayName": "XEChat",
  "description": "XEChat for VSCode",
  "version": "0.0.1",
  "publisher": "xeblog",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:xechat.openChat",
    "onCommand:xechat.connect",
    "onCommand:xechat.disconnect",
    "onCommand:xechat.reconnect",
    "onCommand:xechat.status",
    "onCommand:xechat.openBrowserTool",
    "onCommand:xechat.openReadTool",
    "onCommand:xechat.help",
    "onCommand:xechat.sendMessage",
    "onCommand:xechat.gameDisabledInfo",
    "onCommand:xechat.showGame",
    "onCommand:xechat.play",
    "onCommand:xechat.join",
    "onCommand:xechat.overGame"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xechat.openChat",
        "title": "XEChat: 打开聊天"
      },
      {
        "command": "xechat.connect",
        "title": "XEChat: 连接"
      },
      {
        "command": "xechat.disconnect",
        "title": "XEChat: 断开"
      },
      {
        "command": "xechat.reconnect",
        "title": "XEChat: 重连"
      },
      {
        "command": "xechat.status",
        "title": "XEChat: 状态"
      },
      {
        "command": "xechat.openBrowserTool",
        "title": "XEChat: 浏览器工具"
      },
      {
        "command": "xechat.openReadTool",
        "title": "XEChat: 阅读工具"
      },
      {
        "command": "xechat.help",
        "title": "XEChat: 帮助"
      },
      {
        "command": "xechat.sendMessage",
        "title": "XEChat: 发送消息"
      },
      {
        "command": "xechat.gameDisabledInfo",
        "title": "XEChat: 游戏功能说明（当前阶段不迁移）"
      },
      {
        "command": "xechat.showGame",
        "title": "XEChat: 游戏列表（已禁用）"
      },
      {
        "command": "xechat.play",
        "title": "XEChat: 开始游戏（已禁用）"
      },
      {
        "command": "xechat.join",
        "title": "XEChat: 加入游戏（已禁用）"
      },
      {
        "command": "xechat.overGame",
        "title": "XEChat: 结束游戏（已禁用）"
      }
    ],
    "configuration": {
      "title": "XEChat",
      "properties": {
        "xechat.serverUrl": {
          "type": "string",
          "default": "ws://localhost:1025/xechat",
          "description": "XEChat WebSocket 服务地址"
        },
        "xechat.nickname": {
          "type": "string",
          "default": "xechat_user",
          "description": "XEChat 聊天昵称"
        },
        "xechat.autoReconnect": {
          "type": "boolean",
          "default": true,
          "description": "连接断开后自动重连"
        },
        "xechat.reconnectIntervalSeconds": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "自动重连间隔（秒）"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "typecheck": "tsc -p ./ --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "ws": "^8.18.0"
  }
}
